---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  permalink: string;
  current?: string;
  image?: string;
}

const { title, description, permalink, current, image } = Astro.props;
---
<html lang="en">
<head>
  <BaseHead title={title} description={description} permalink={permalink} image={image} />
</head>
<body class="bg-gradient-to-br from-slate-50 via-white to-slate-100 text-slate-900 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 dark:text-slate-100 antialiased">
  <div class="flex flex-col min-h-screen">
    <Header current={current} />

    <main class="flex-1 py-8 px=0">
      <slot />
    </main>

    <Footer />
  </div>
</body>
</html>
