---
const { current = '' } = Astro.props;
const navItems = [
  { label: 'home', href: '/' },
  { label: 'about', href: '/about' },
  { label: 'challenges', href: '/challenges' },
  { label: 'blog', href: '/blog' },
];
const projectsDropdown = [
  { label: 'all projects', href: '/projects' },
  { label: 'enchanter', href: '/projects/enchanter' },
  { label: 'erwinmvc', href: '/projects/erwinmvc' },
  { label: 'arcmvc', href: '/projects/arcmvc' },
  { label: 'imsai 8080 emulator', href: '/projects/imsai-8080-emulator' },
  { label: 'go nes emulator', href: '/projects/go-nes-emulator' },
  { label: 'ocaml mandelbrot', href: '/projects/ocaml-mandelbrot' },
  { label: 'rust pet emulator', href: '/projects/rust-pet-emulator' },
];
const demosDropdown = [
  { label: 'all demos', href: '/demos' },
  { label: 'game of life', href: '/demos/conway' },
  { label: 'mandelbrot', href: '/demos/mandelbrot' },
  { label: 'nes emulator', href: '/demos/nes' },
  { label: 'sudoku', href: '/demos/sudoku' },
  { label: 'wordle', href: '/demos/wordle' },
  { label: 'enigma', href: '/demos/enigma' },
  { label: 'multiplayer dungeon', href: '/demos/dungeon' },
];
---

<header class="border-b border-terminal-border bg-terminal-bg">
  <div class="max-w-3xl mx-auto px-4 py-4">
    <div
      class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4"
    >
      <h1>
        <a
          href="/"
          class="text-terminal-green hover:text-terminal-cyan no-underline"
        >
          andrew@thecoder:~$
        </a>
      </h1>

      <nav class="flex flex-wrap gap-4 text-sm items-center">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={`no-underline ${
                current == item.label
                  ? 'text-terminal-green'
                  : 'text-terminal-dim hover:text-terminal-fg'
              }`}
            >
              {current == item.label ? `[${item.label}]` : item.label}
            </a>
          ))
        }

        <div class="relative group">
          <button
            class={`no-underline cursor-pointer bg-transparent border-none ${
              current == 'projects'
                ? 'text-terminal-green'
                : 'text-terminal-dim hover:text-terminal-fg'
            }`}
          >
            {current == 'projects' ? '[projects]' : 'projects'}
            <span class="text-xs ml-0.5">▼</span>
          </button>
          <div
            class="absolute left-0 top-full pt-1 hidden group-hover:block min-w-max z-50"
          >
            <div class="bg-terminal-bg border border-terminal-border rounded">
              {
                projectsDropdown.map((item) => (
                  <a
                    href={item.href}
                    class="block px-3 py-2 text-terminal-dim hover:text-terminal-fg hover:bg-terminal-border no-underline whitespace-nowrap"
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <div class="relative group">
          <button
            class={`no-underline cursor-pointer bg-transparent border-none ${
              current == 'demos'
                ? 'text-terminal-green'
                : 'text-terminal-dim hover:text-terminal-fg'
            }`}
          >
            {current == 'demos' ? '[demos]' : 'demos'}
            <span class="text-xs ml-0.5">▼</span>
          </button>
          <div
            class="absolute left-0 top-full pt-1 hidden group-hover:block min-w-max z-50"
          >
            <div class="bg-terminal-bg border border-terminal-border rounded">
              {
                demosDropdown.map((item) => (
                  <a
                    href={item.href}
                    class="block px-3 py-2 text-terminal-dim hover:text-terminal-fg hover:bg-terminal-border no-underline whitespace-nowrap"
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>
