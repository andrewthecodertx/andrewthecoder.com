---
const { current = '' } = Astro.props;
const navmenu = [
    { label: "home", href: "/" },
    { label: "about", href: "/about" },
    { label: "projects", href: "/projects" },
    { label: "blog", href: "/blog" }
];
---

<header class="border-b border-[#2a2a2a] bg-[#0a0a0a]">
    <div class="max-w-3xl mx-auto px-4 py-4">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
            <a href="/" class="text-[#4ade80] hover:text-[#22d3ee] no-underline">
                andrew@thecoder:~$
            </a>

            <nav class="flex flex-wrap gap-4 text-sm">
                {navmenu.map((item) => (
                    <a
                        href={item.href}
                        class={`no-underline ${current == item.label
                            ? "text-[#4ade80]"
                            : "text-[#6b7280] hover:text-[#e0e0e0]"}`}
                    >
                        {current == item.label ? `[${item.label}]` : item.label}
                    </a>
                ))}
            </nav>
        </div>
    </div>
</header>
