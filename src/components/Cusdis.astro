---
interface Props {
  pageId: string;
  pageUrl: string;
  pageTitle: string;
}

const { pageId, pageUrl, pageTitle } = Astro.props;

// Configure these environment variables or update the defaults
const host = import.meta.env.PUBLIC_CUSDIS_HOST || 'https://cusdis.example.com';
const appId = import.meta.env.PUBLIC_CUSDIS_APP_ID || '';
---

<div
  id="cusdis_thread"
  data-host={host}
  data-app-id={appId}
  data-page-id={pageId}
  data-page-url={pageUrl}
  data-page-title={pageTitle}
>
</div>

<script>
  function loadCusdis() {
    const host = document.getElementById('cusdis_thread')?.dataset.host;
    if (!host) return;

    // Set theme based on current dark mode
    const thread = document.getElementById('cusdis_thread');
    if (thread) {
      const isDark = document.documentElement.classList.contains('dark');
      thread.dataset.theme = isDark ? 'dark' : 'light';
    }

    // Load Cusdis script
    const script = document.createElement('script');
    script.src = host + '/js/cusdis.es.js';
    script.async = true;
    script.defer = true;
    document.body.appendChild(script);
  }

  // Load on page ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadCusdis);
  } else {
    loadCusdis();
  }

  // Re-render on theme change
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'class') {
        const thread = document.getElementById('cusdis_thread');
        if (thread && window.CUSDIS) {
          const isDark = document.documentElement.classList.contains('dark');
          thread.dataset.theme = isDark ? 'dark' : 'light';
          window.CUSDIS.setTheme(isDark ? 'dark' : 'light');
        }
      }
    });
  });

  observer.observe(document.documentElement, { attributes: true });
</script>
