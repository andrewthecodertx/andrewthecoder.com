---
import { CONTACT_EMAIL } from '../constants';
---

<footer class="border-t border-[#2a2a2a] mt-16">
    <div class="max-w-3xl mx-auto px-4 py-6">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-[#6b7280]">
            <p>&copy; {new Date().getFullYear()} andrew erwin</p>
            <div class="flex gap-4">
                <a href="https://github.com/andrewthecodertx" target="_blank" rel="noopener noreferrer" class="hover:text-[#4ade80] no-underline">github</a>
                <a href="/rss.xml" class="hover:text-[#4ade80] no-underline">rss</a>
                <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-[#4ade80] no-underline">email</a>
            </div>
        </div>
    </div>
</footer>
