---
import ThemeToggleButton from './ThemeToggleButton.svelte';
const { current = '' } = Astro.props;
---

<style>
  nav {
    display: flex;
    align-items: center;
    font-family: var(--font-family-sans);
    font-weight: 700;
    text-transform: uppercase;
  }

  a {
    color: var(--text-main);
    text-decoration: none;
    padding: 0.5em 0.8em; /* Adjusted padding */
    margin-left: 1em; /* Adjusted margin */
    transition: color 0.2s ease-in-out;
  }

  a:hover {
    color: var(--primary-color);
  }

  a.selected {
    color: var(--primary-color);
  }

  .theme-toggle-container {
    /* This rule is now empty as styles are moved to ThemeToggleButton.svelte */
  }

  @media screen and (max-width: 520px) {
    nav {
      flex-direction: column;
      margin-top: 1em;
    }

    a {
      margin: 0.5em 0; /* Adjusted margin for vertical layout */
    }

    .theme-toggle-container {
      /* This rule is now empty as styles are moved to ThemeToggleButton.svelte */
    }
  }
</style>

<nav>
  <a class={current === "" ? "selected" : ""} href='/'>home</a>
  <a class={current === "about" ? "selected" : ""} href='/about'>about</a>
  <a class={current === "blog" ? "selected" : ""} href='/blog'>blog</a>
  <a class={current === "projects" ? "selected" : ""} href='/projects'>projects</a>
  <a class={current === "search" ? "selected" : ""} href='/search'>search</a>
  <div class="theme-toggle-container">
    <ThemeToggleButton client:load />
  </div>
</nav>
