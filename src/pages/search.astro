---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/Search.svelte';

const title = 'Search Blogs';
const description = 'Search all blog posts.';
const permalink = `${Astro.site.href}search`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="search" noindex={true}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <section class="py-12 lg:py-16">
      <div class="text-center max-w-3xl mx-auto mb-8">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 dark:text-amber-50 mb-4">
          Search Blog Posts
        </h1>
        <p class="text-xl text-gray-600 dark:text-amber-200">
          Find articles by title, description, or content
        </p>
      </div>

      <!-- Search Component Container -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 lg:p-8
      border border-gray-200 dark:border-gray-700">
        <Search client:load />
      </div>
    </section>

    <!-- Search Tips -->
    <section class="pb-12 lg:pb-16">
      <div class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-gray-800
      dark:to-gray-700 rounded-xl p-6 lg:p-8 border border-blue-200
      dark:border-gray-600">
        <h2 class="text-xl font-bold text-gray-900 dark:text-amber-50 mb-4
        flex items-center gap-2">
          <svg class="w-6 h-6 text-blue-500 dark:text-blue-400" fill="none"
          stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Search Tips
        </h2>
        <ul class="space-y-2 text-gray-700 dark:text-amber-200">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-500 dark:text-blue-400 mt-0.5 flex-shrink-0"
            fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Type keywords to search across all blog post titles and descriptions</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-500 dark:text-blue-400 mt-0.5 flex-shrink-0"
            fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Search is case-insensitive and updates results in real-time</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-500 dark:text-blue-400 mt-0.5 flex-shrink-0"
            fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Click on any result to read the full blog post</span>
          </li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
