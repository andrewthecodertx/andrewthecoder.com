---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Projects';
const description = 'A collection of my projects.';
const permalink = `${Astro.site.href}projects`;

let projects = [];

try {
  const response = await fetch(
    'https://api.github.com/search/repositories?q=user:andrewthecodertx+topic:portfolio-project',
    {
      headers: {
        'Accept': 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28'
      }
    });
  const data = await response.json();
  projects = data.items?.map((item: any) => ({
    name: item.name,
    description: item.description || 'No description provided',
    url: item.html_url,
    language: item.language || 'Unknown',
    homepage: item.homepage || ''
  })) || [];
} catch (error) {
  console.error('Error fetching projects:', error);
}

function formatProjectTitle(name: string) {
  return name.replace(/-/g, ' ');
}
---

<BaseLayout title={title} description={description} permalink={permalink} current="projects">
  <div class="max-w-3xl mx-auto px-4">

    <section class="py-12">
        <h2 class="text-terminal-amber mb-8">## websites</h2>

        <p class="text-terminal-dim mb-8">
            Some websites I have built...
        </p>

        <ul class="space-y-6">
            <li>
                <a href="https://bruiserslegacy.org" class="text-terminal-cyan">Bruiser's Legact</a> is a small
                animal rescue in southeastern Wisconsin.
            </li>
            <li>
                <a href="https://weightogether.com" class="text-terminal-cyan">Weigh Together</a> is a weight
                and fitness tracking platform that combines personal progress
                monitoring with team-based accountability. Users can log their
                weight, add progress photos, view charts and insights, join
                accountability groups, and participate in challenges with
                others. The platform supports various fitness activities
                including running, strength training, and hiking, with a
                focus on community support and celebrating milestones together.
            </li>
        </ul>

    </section>
        
    <section class="py-12">
      <h2 class="text-terminal-amber mb-8">## projects</h2>

      <p class="text-terminal-dim mb-8">
        Things I've built. Some useful, some just for fun.
                <a href="https://github.com/andrewthecodertx" target="_blank"
                    rel="noopener noreferrer" class="text-terminal-cyan hover:text-terminal-green no-underline">See all on GitHub →</a>
      </p>

      {projects.length > 0 ? (
        <ul class="space-y-6">
          {projects.map((project) => (
            <li class="border-b border-terminal-border pb-6">
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 mb-2">
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-terminal-fg hover:text-terminal-green no-underline font-medium"
                >
                  {formatProjectTitle(project.name)}
                </a>
                <span class="text-terminal-dim text-sm">[{project.language}]</span>
              </div>
              <p class="text-terminal-dim text-sm mb-3">{project.description}</p>
              <div class="flex gap-4 text-sm">
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-terminal-cyan hover:text-terminal-green no-underline"
                >
                  source →
                </a>
                {project.homepage && (
                  <a
                    href={project.homepage}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-terminal-cyan hover:text-terminal-green no-underline"
                  >
                    demo →
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-terminal-dim">No projects found. Check back later.</p>
      )}
    </section>

  </div>
</BaseLayout>
