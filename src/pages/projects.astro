---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Projects';
const description = 'A collection of my projects.';
const permalink = `${Astro.site.href}projects`;

let projects = [];
let data = null;

try {
  const response = await fetch(
    'https://api.github.com/search/repositories?q=user:andrewthecodertx+topic:portfolio-project',
    {
      headers: {
        'Accept': 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28'
      }
    });
  data = await response.json();
} catch (error) {
  console.error('Error fetching projects:', error);
  projects = []; // Fallback to an empty array if the fetch fails
  return;
}

projects = data.items.map((item : any) => ({
  name: item.name,
  description: item.description || 'No description provided',
  url: item.html_url,
  language: item.language || 'Unknown',
  homepage: item.homepage || '',
  features: item.topics || []
}));
---

<BaseLayout title={title} description={description} permalink={permalink} current="projects">
  <div class="container">
    <h2>My Projects</h2>
    <div class="projects-grid">
      {projects.map((project) => (
        <div class="project-card">
          <h3><a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a></h3>
          <p>{project.description}</p>
          <p>Language: {project.language}</p>
          {project.homepage && (
            <a href={project.homepage} target="_blank" rel="noopener noreferrer">CHEK IT OUT HERE</a>
          )}
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5em; /* Slightly reduced gap */
    margin-top: 2.5em; /* Adjusted margin */
  }

  .project-card {
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5em;
    background-color: var(--card-background);
    box-shadow: none; /* Removed box-shadow for a simpler look */
    transition: transform 0.2s ease-in-out; /* Add subtle hover effect */
  }

  .project-card:hover {
    transform: translateY(-5px); /* Lift card on hover */
  }

  .project-card h2 {
    margin-top: 0;
    font-size: 1.4em; /* Adjusted font size */
  }

  .project-card h2 a {
    text-decoration: none;
    color: var(--text-main); /* Use main text color by default */
  }

  .project-card h2 a:hover {
    text-decoration: underline;
    color: var(--primary-color); /* Primary color on hover */
  }

  .project-card p {
    color: var(--text-secondary);
    margin-bottom: 1em;
  }

  .project-features {
    list-style: disc;
    margin-left: 1.2em; /* Slightly reduced margin */
    color: var(--text-secondary);
  }

  .project-features li {
    margin-bottom: 0.3em; /* Reduced margin */
  }
</style>
