---
import DemoLayout from '../../layouts/DemoLayout.astro';

export const prerender = true;

const title = 'Enigma Machine';
const description =
  'Interactive Enigma M3 cipher machine emulator. Encrypt and decrypt messages using the historical WWII German encryption device.';
const permalink = `${Astro.site.href}demos/enigma`;
const image = '/assets/demos/enigma.webp';

const row1 = ['Q', 'W', 'E', 'R', 'T', 'Z', 'U', 'I', 'O'];
const row2 = ['A', 'S', 'D', 'F', 'G', 'H', 'J', 'K', 'L'];
const row3 = ['P', 'Y', 'X', 'C', 'V', 'B', 'N', 'M'];
---

<DemoLayout
  title={title}
  description={description}
  permalink={permalink}
  current="demos"
  image={image}
>
  <div
    class="px-4 py-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm border-b border-terminal-border"
  >
    <h2 class="text-terminal-green">Enigma M3</h2>
    <span class="text-terminal-dim">
      <span class="text-terminal-amber">type</span> or
      <span class="text-terminal-amber">click</span> keys
      <span class="px-1">·</span>
      <span class="text-terminal-amber">a-z</span> encrypt
    </span>
    <div class="flex gap-2 ml-auto">
      <a
        href="https://github.com/andrewthecodertx/M3-Enigma-Machine"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors no-underline"
      >
        [source]
      </a>
    </div>
  </div>

  <div class="px-4 py-6 space-y-6 max-w-lg mx-auto">
    <!-- Rotors -->
    <div class="space-y-3">
      <h3
        class="text-terminal-amber text-xs uppercase tracking-widest text-center"
      >
        rotors
      </h3>
      <div class="flex justify-center gap-4">
        <div
          class="flex flex-col items-center gap-1 bg-terminal-bg/50 border border-terminal-border rounded p-3 min-w-[100px]"
        >
          <label class="text-terminal-dim text-[10px] uppercase tracking-wider"
            >left</label
          >
          <div class="flex items-center gap-2">
            <select
              id="enigma-left-rotor-type"
              class="bg-terminal-bg border border-terminal-border text-terminal-fg text-xs px-1.5 py-1 font-mono rounded cursor-pointer"
            >
              <option value="I">I</option>
              <option value="II">II</option>
              <option value="III">III</option>
              <option value="IV" selected>IV</option>
              <option value="V">V</option>
            </select>
            <span
              id="enigma-left-pos"
              class="text-terminal-green font-mono text-xl bg-terminal-bg border border-terminal-green/30 px-2.5 py-0.5 rounded min-w-[2ch] text-center inline-block"
              >J</span
            >
          </div>
          <label class="text-terminal-dim text-[10px] flex items-center gap-1"
            >ring
            <input
              id="enigma-left-ring"
              type="number"
              min="0"
              max="25"
              value="0"
              class="bg-terminal-bg border border-terminal-border text-terminal-fg text-xs w-10 px-1 py-0.5 font-mono rounded text-center"
            />
          </label>
        </div>

        <div
          class="flex flex-col items-center gap-1 bg-terminal-bg/50 border border-terminal-border rounded p-3 min-w-[100px]"
        >
          <label class="text-terminal-dim text-[10px] uppercase tracking-wider"
            >mid</label
          >
          <div class="flex items-center gap-2">
            <select
              id="enigma-middle-rotor-type"
              class="bg-terminal-bg border border-terminal-border text-terminal-fg text-xs px-1.5 py-1 font-mono rounded cursor-pointer"
            >
              <option value="I">I</option>
              <option value="II">II</option>
              <option value="III" selected>III</option>
              <option value="IV">IV</option>
              <option value="V">V</option>
            </select>
            <span
              id="enigma-middle-pos"
              class="text-terminal-green font-mono text-xl bg-terminal-bg border border-terminal-green/30 px-2.5 py-0.5 rounded min-w-[2ch] text-center inline-block"
              >V</span
            >
          </div>
          <label class="text-terminal-dim text-[10px] flex items-center gap-1"
            >ring
            <input
              id="enigma-middle-ring"
              type="number"
              min="0"
              max="25"
              value="0"
              class="bg-terminal-bg border border-terminal-border text-terminal-fg text-xs w-10 px-1 py-0.5 font-mono rounded text-center"
            />
          </label>
        </div>

        <div
          class="flex flex-col items-center gap-1 bg-terminal-bg/50 border border-terminal-border rounded p-3 min-w-[100px]"
        >
          <label class="text-terminal-dim text-[10px] uppercase tracking-wider"
            >right</label
          >
          <div class="flex items-center gap-2">
            <select
              id="enigma-right-rotor-type"
              class="bg-terminal-bg border border-terminal-border text-terminal-fg text-xs px-1.5 py-1 font-mono rounded cursor-pointer"
            >
              <option value="I">I</option>
              <option value="II">II</option>
              <option value="III">III</option>
              <option value="IV">IV</option>
              <option value="V" selected>V</option>
            </select>
            <span
              id="enigma-right-pos"
              class="text-terminal-green font-mono text-xl bg-terminal-bg border border-terminal-green/30 px-2.5 py-0.5 rounded min-w-[2ch] text-center inline-block"
              >Z</span
            >
          </div>
          <label class="text-terminal-dim text-[10px] flex items-center gap-1"
            >ring
            <input
              id="enigma-right-ring"
              type="number"
              min="0"
              max="25"
              value="0"
              class="bg-terminal-bg border border-terminal-border text-terminal-fg text-xs w-10 px-1 py-0.5 font-mono rounded text-center"
            />
          </label>
        </div>
      </div>
    </div>

    <!-- Plugboard -->
    <div class="space-y-1">
      <h3
        class="text-terminal-amber text-xs uppercase tracking-widest text-center"
      >
        plugboard
      </h3>
      <input
        id="enigma-plugboard"
        type="text"
        value="AZ BY CX TD SW"
        maxlength="30"
        placeholder="AZ BY CX"
        class="bg-terminal-bg border border-terminal-border text-terminal-fg text-sm px-3 py-1.5 font-mono rounded w-full focus:border-terminal-cyan focus:outline-none"
      />
      <div id="enigma-plugboard-error" class="text-red-400 text-xs"></div>
    </div>

    <!-- Lampboard -->
    <div class="space-y-2">
      <h3
        class="text-terminal-amber text-xs uppercase tracking-widest text-center"
      >
        lampboard
      </h3>
      <div
        class="bg-terminal-bg border border-terminal-border rounded-lg p-4 flex flex-col items-center gap-2"
      >
        <div class="flex justify-center gap-1.5">
          {
            row1.map((letter) => (
              <div
                class="enigma-lamp w-10 h-10 rounded-full border-2 border-terminal-border flex items-center justify-center text-sm font-mono transition-all duration-150"
                data-letter={letter}
              >
                {letter}
              </div>
            ))
          }
        </div>
        <div class="flex justify-center gap-1.5">
          {
            row2.map((letter) => (
              <div
                class="enigma-lamp w-10 h-10 rounded-full border-2 border-terminal-border flex items-center justify-center text-sm font-mono transition-all duration-150"
                data-letter={letter}
              >
                {letter}
              </div>
            ))
          }
        </div>
        <div class="flex justify-center gap-1.5">
          {
            row3.map((letter) => (
              <div
                class="enigma-lamp w-10 h-10 rounded-full border-2 border-terminal-border flex items-center justify-center text-sm font-mono transition-all duration-150"
                data-letter={letter}
              >
                {letter}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Keyboard -->
    <div class="space-y-2">
      <h3
        class="text-terminal-amber text-xs uppercase tracking-widest text-center"
      >
        keyboard
      </h3>
      <div class="flex flex-col items-center gap-2">
        <div class="flex justify-center gap-1.5">
          {
            row1.map((letter) => (
              <button
                class="enigma-key w-10 h-10 rounded-full border border-terminal-border bg-terminal-bg text-terminal-fg font-mono text-sm hover:bg-terminal-border hover:text-terminal-green active:bg-terminal-green/20 transition-all duration-100"
                data-key={letter}
              >
                {letter}
              </button>
            ))
          }
        </div>
        <div class="flex justify-center gap-1.5">
          {
            row2.map((letter) => (
              <button
                class="enigma-key w-10 h-10 rounded-full border border-terminal-border bg-terminal-bg text-terminal-fg font-mono text-sm hover:bg-terminal-border hover:text-terminal-green active:bg-terminal-green/20 transition-all duration-100"
                data-key={letter}
              >
                {letter}
              </button>
            ))
          }
        </div>
        <div class="flex justify-center gap-1.5">
          {
            row3.map((letter) => (
              <button
                class="enigma-key w-10 h-10 rounded-full border border-terminal-border bg-terminal-bg text-terminal-fg font-mono text-sm hover:bg-terminal-border hover:text-terminal-green active:bg-terminal-green/20 transition-all duration-100"
                data-key={letter}
              >
                {letter}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Input / Output -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <h3
          class="text-terminal-amber text-xs uppercase tracking-widest text-center"
        >
          input
        </h3>
        <textarea
          id="enigma-input"
          rows="3"
          placeholder="Type a message..."
          class="w-full bg-terminal-bg border border-terminal-border text-terminal-fg text-sm p-2 font-mono rounded resize-none focus:border-terminal-cyan focus:outline-none"
        ></textarea>
        <div class="flex gap-2">
          <button
            id="enigma-process"
            class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-1 cursor-pointer font-mono transition-colors text-xs"
          >
            encrypt/decrypt
          </button>
          <button
            id="enigma-reset"
            class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-1 cursor-pointer font-mono transition-colors text-xs"
          >
            reset
          </button>
        </div>
      </div>
      <div class="space-y-1">
        <h3
          class="text-terminal-amber text-xs uppercase tracking-widest text-center"
        >
          output
        </h3>
        <textarea
          id="enigma-output"
          readonly
          rows="3"
          class="w-full bg-terminal-bg border border-terminal-border text-terminal-green text-sm p-2 font-mono rounded resize-none focus:outline-none"
        ></textarea>
        <button
          id="enigma-copy"
          class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-1 cursor-pointer font-mono transition-colors text-xs"
        >
          copy
        </button>
      </div>
    </div>
  </div>

  <style>
    .enigma-lamp.active {
      background-color: #4ade80;
      color: #0a0a0a;
      border-color: #4ade80;
      box-shadow:
        0 0 12px #4ade8080,
        0 0 24px #4ade8040;
      font-weight: bold;
    }
    .enigma-key.pressed {
      background-color: #22d3ee;
      color: #0a0a0a;
      border-color: #22d3ee;
    }
  </style>

  <script is:inline src="/js/enigma.js" data-astro-rerun></script>
</DemoLayout>
