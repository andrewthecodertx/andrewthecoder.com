---
import DemoLayout from '../../layouts/DemoLayout.astro';

export const prerender = true;

const title = 'Tetris';
const description =
  'Classic Tetris clone written in TypeScript. Play with keyboard (arrows, Space, A/D) or on-screen controls. Built with HTML5 Canvas.';
const permalink = `${Astro.site.href}demos/tetris`;
const image = '/assets/demos/tetris.webp';
---

<DemoLayout
  title={title}
  description={description}
  permalink={permalink}
  current="demos"
  image={image}
>
  <div
    class="px-4 py-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm border-b border-terminal-border"
  >
    <h2 class="text-terminal-green">Tetris</h2>
    <span class="text-terminal-dim">
      <span class="text-terminal-amber">Space</span> start
      <span class="px-1">·</span>
      <span class="text-terminal-amber">arrows</span> move
      <span class="px-1">·</span>
      <span class="text-terminal-amber">A/D</span> rotate
    </span>
    <div class="flex gap-2 ml-auto">
      <a
        href="https://github.com/andrewthecodertx/typescript-tetris"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors no-underline"
      >
        [source]
      </a>
    </div>
  </div>

  <div
    class="tetris-game font-retro flex flex-col items-center bg-gray-700 py-6 px-4"
  >
    <div
      class="flex flex-col md:flex-row w-full max-w-4xl bg-zinc-50 justify-around"
      id="tetris"
    >
      <div class="flex flex-col justify-items-center w-[260px]" id="left">
        <div class="flex justify-center mt-5 mb-9">
          <span
            class="bg-black text-white border-4 border-cyan-500 w-fit py-1 px-2 mb-2"
            id="type"
          >
            <p>A-TYPE</p>
          </span>
        </div>

        <div
          class="flex flex-col bg-black text-white border-4 border-cyan-500 justify-center p-1"
        >
          <p class="justify-center m-auto">STATISTICS</p>
          <div class="p-4 m-auto" id="stats">
            <ul></ul>
          </div>
        </div>

        <div class="font-sans text-terminal-dim">
          <p>CONTROLS</p>
          <p>Press SPACE to start</p>
          <p>Arrow keys to move</p>
          <p>VIM keys (H,J,L) also move</p>
          <p>A and D rotate</p>
        </div>
      </div>

      <div class="flex flex-col" id="center">
        <div
          class="w-full p-2 m-auto flex justify-center border-4 border-cyan-500 bg-black text-white mb-2"
        >
          <p>
            LINES-<span id="lines" class="text-terminal-green">000</span>
          </p>
        </div>
        <canvas
          class="border-cyan-500 border-4"
          id="gamearena"
          height="600"
          width="300"
          style="image-rendering: pixelated; image-rendering: crisp-edges;"
        ></canvas>
      </div>

      <div class="w-[260px]" id="right">
        <div id="scoreboard">
          <div class="bg-terminal-bg border border-terminal-border p-3">
            <p class="text-terminal-amber font-mono text-xs">SCORE</p>
            <span
              id="score"
              class="text-terminal-green font-mono text-2xl block mt-1">0</span
            >
          </div>
          <div class="bg-terminal-bg border border-terminal-border p-3 mt-2">
            <p class="text-terminal-amber font-mono text-xs">NEXT</p>
            <canvas
              id="bullpen"
              height="80"
              width="80"
              class="mt-2 border border-terminal-border"></canvas>
          </div>
          <div class="bg-terminal-bg border border-terminal-border p-3 mt-2">
            <p class="text-terminal-amber font-mono text-xs">LEVEL</p>
            <span
              id="level"
              class="text-terminal-green font-mono text-2xl block mt-1">00</span
            >
          </div>
        </div>
      </div>

      <div id="mobile-controls" class="md:hidden flex justify-center mt-4">
        <button id="left-btn" class="p-4 mx-2 bg-gray-300 rounded">Left</button>
        <button id="right-btn" class="p-4 mx-2 bg-gray-300 rounded">
          Right
        </button>
        <button id="rotate-btn" class="p-4 mx-2 bg-gray-300 rounded">
          Rotate
        </button>
        <button id="down-btn" class="p-4 mx-2 bg-gray-300 rounded">Down</button>
      </div>
    </div>
  </div>

  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />
  <link rel="stylesheet" href="/tetris/assets/tetris.css" />
  <script is:inline src="/tetris/assets/tetris.js" data-astro-rerun></script>
</DemoLayout>
