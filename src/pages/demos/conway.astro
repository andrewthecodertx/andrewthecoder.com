---
import DemoLayout from '../../layouts/DemoLayout.astro';

export const prerender = true;

const title = "Conway's Game of Life";
const description = "Interactive in-browser implementation of John Conway's Game of Life. Tap or drag to draw cells, watch them evolve, restart or clear at any time.";
const permalink = `${Astro.site.href}demos/conway`;
---

<DemoLayout title={title} description={description} permalink={permalink} current="demos" image="/assets/gameoflife.webp">
	<div class="px-4 py-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm border-b border-terminal-border">
		<h2 class="text-terminal-green">John Conway's Game of Life</h2>
		<span class="text-terminal-dim">
			<span class="text-terminal-amber">tap</span> toggle
			<span class="px-1">·</span>
			<span class="text-terminal-amber">drag</span> draw
			<span class="hidden sm:inline">
				<span class="px-1">·</span>
				<span class="text-terminal-amber">space</span> pause
				<span class="px-1">·</span>
				<span class="text-terminal-amber">r</span> restart
				<span class="px-1">·</span>
				<span class="text-terminal-amber">c</span> clear
			</span>
		</span>
		<div class="flex gap-2 ml-auto">
			<button
				id="pauseButton"
				class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors"
			>
				[pause]
			</button>
			<button
				id="restartButton"
				class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors"
			>
				[restart]
			</button>
			<button
				id="clearButton"
				class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors"
			>
				[clear]
			</button>
		</div>
	</div>

	<canvas id="gameCanvas" class="bg-terminal-bg block w-full touch-none"></canvas>

	<script is:inline src="/js/conway.js" data-astro-rerun></script>
</DemoLayout>
