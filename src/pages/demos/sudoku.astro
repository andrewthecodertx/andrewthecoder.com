---
import DemoLayout from '../../layouts/DemoLayout.astro';

export const prerender = true;

const title = 'Sudoku';
const description =
  'Sudoku solver and generator. Generate puzzles, fill in numbers, and solve with backtracking. Click and type, or use the number pad.';
const permalink = `${Astro.site.href}demos/sudoku`;
const image = '/assets/demos/sudoku.webp';
---

<DemoLayout
  title={title}
  description={description}
  permalink={permalink}
  current="demos"
  image={image}
>
  <div
    class="px-4 py-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm border-b border-terminal-border"
  >
    <h2 class="text-terminal-green">Sudoku</h2>
    <span class="text-terminal-dim">
      <span class="text-terminal-amber">click</span> select
      <span class="px-1">·</span>
      <span class="text-terminal-amber">1-9</span> fill
      <span class="px-1">·</span>
      <span class="text-terminal-amber">hjkl</span> move
    </span>
    <div class="flex gap-2 ml-auto">
      <a
        href="https://github.com/andrewthecodertx/javascript-sudokusolver"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors no-underline"
      >
        [source]
      </a>
    </div>
  </div>

  <div
    class="px-4 py-2 flex flex-wrap items-center gap-x-2 gap-y-2 text-xs border-b border-terminal-border bg-terminal-bg/50"
  >
    <button
      id="sudoku-generate"
      class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors"
    >
      generate
    </button>
    <button
      id="sudoku-solve"
      disabled
      class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
    >
      solve
    </button>
    <button
      id="sudoku-check"
      disabled
      class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
    >
      check
    </button>
    <button
      id="sudoku-clear"
      class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors"
    >
      clear
    </button>
    <span id="sudoku-check-result" class="text-terminal-dim ml-2"></span>
  </div>

  <div class="flex flex-col items-center px-4 py-4">
    <canvas id="sudoku-grid" class="block max-w-[500px] w-full"></canvas>
    <div id="sudoku-number-pad" class="grid grid-cols-2 gap-2 mt-4">
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        1
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        2
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        3
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        4
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        5
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        6
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        7
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        8
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-fg hover:text-terminal-green hover:border-terminal-green transition-colors rounded"
      >
        9
      </button>
      <button
        class="w-11 h-11 font-mono text-lg border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-amber hover:border-terminal-amber transition-colors rounded"
      >
        C
      </button>
    </div>
  </div>

  <script is:inline src="/js/sudoku.js" data-astro-rerun></script>
</DemoLayout>
