---
import DemoLayout from '../../layouts/DemoLayout.astro';

export const prerender = true;

const title = 'Wordle';
const description =
  'A browser-based Wordle clone built with TypeScript. Guess the 5-letter word in 6 tries with color-coded feedback.';
const permalink = `${Astro.site.href}demos/wordle`;
const image = '/assets/demos/wordle.webp';
---

<DemoLayout
  title={title}
  description={description}
  permalink={permalink}
  current="demos"
  image={image}
>
  <div
    class="px-4 py-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm border-b border-terminal-border"
  >
    <h2 class="text-terminal-green">Wordle</h2>
    <span class="text-terminal-dim">
      <span class="text-terminal-amber">type</span> letters
      <span class="px-1">·</span>
      <span class="text-terminal-amber">enter</span> submit
      <span class="px-1">·</span>
      <span class="text-terminal-amber">⌫</span> delete
    </span>
    <div class="flex gap-2 ml-auto">
      <a
        href="https://github.com/andrewthecodertx/typescript-wordle"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-terminal-border bg-terminal-bg text-terminal-dim hover:text-terminal-green hover:border-terminal-green px-3 py-0.5 cursor-pointer font-mono transition-colors no-underline"
      >
        [source]
      </a>
    </div>
  </div>

  <div class="wordle-container">
    <div id="wordle-message" class="wordle-message"></div>
    <div id="wordle-board" class="wordle-board"></div>
    <div id="wordle-keyboard" class="wordle-kb"></div>
    <button id="wordle-new-game" class="wordle-new-game">[ new game ]</button>
  </div>

  <script is:inline src="/js/wordle.js" data-astro-rerun></script>
</DemoLayout>
