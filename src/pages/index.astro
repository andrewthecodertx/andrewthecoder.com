---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = 'Andrew the Coder';
const description = 'Software Engineer and Web Developer';
const permalink = Astro.site.href;

const allPosts = await getCollection('posts');
const featuredPosts = allPosts.filter(post => post.data.featured);
featuredPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

const latestPosts = featuredPosts.slice(0, 3);

let dadJoke = {
  joke_text: "Why do programmers prefer dark mode? Because light attracts bugs!",
  author: "Anonymous"
};

try {
  const response = await fetch('https://dadjokes.developersandbox.xyz/api/v2/random');
  if (response.ok) {
    dadJoke = await response.json();
  }
} catch (error) {
  console.error('Failed to fetch dad joke:', error);
}
---

<BaseLayout title={title} description={description} permalink={permalink} current="home">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Hero Section -->
        <section class="py-12 lg:py-20">
            <div class="flex flex-col lg:flex-row items-center gap-12">
                <div class="flex-1 space-y-6">
                    <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 dark:text-amber-50 leading-tight">
                        Hi, I'm <span class="text-blue-500 dark:text-blue-400">Andrew</span>.
                    </h1>
                    <p class="text-xl lg:text-2xl text-gray-700 dark:text-amber-100 leading-relaxed">
                        Software Engineer & Web Developer with over 20 years of experience.
                    </p>
                    <p class="text-lg text-gray-600 dark:text-amber-200 leading-relaxed">
                        I enjoy the problem-solving aspect of software development and am always
                        looking for new challenges. I also hold advanced degrees in theology and
                        linguistics, and my major hobby is music (I'm a guitar player).
                    </p>
                    <div class="flex flex-wrap gap-4 pt-4">
                        <a
                            href="mailto:info@andrewthecoder.com"
                            class="inline-flex items-center px-6 py-3 bg-blue-500 hover:bg-blue-600
                            dark:bg-blue-600 dark:hover:bg-blue-700 text-white font-semibold
                            rounded-lg transition-colors duration-200 shadow-lg hover:shadow-xl"
                        >
                            Get in Touch
                        </a>
                        <a
                            href="/about"
                            class="inline-flex items-center px-6 py-3 border-2 border-blue-500
                            dark:border-blue-400 text-blue-500 dark:text-blue-400
                            hover:bg-blue-50 dark:hover:bg-blue-900/20 font-semibold
                            rounded-lg transition-colors duration-200"
                        >
                            Learn More
                        </a>
                    </div>
                </div>
                <div class="flex-1 lg:flex lg:justify-end">
                    <div class="w-full max-w-md">
                        <div class="aspect-square bg-gradient-to-br from-blue-400 to-blue-600
                        dark:from-blue-500 dark:to-blue-800 rounded-2xl shadow-2xl
                        transform hover:scale-105 transition-transform duration-300
                        flex items-center justify-center">
                            <img
                                src="/assets/andrew.jpg"
                                alt="Andrew the Coder"
                                class="w-64 h-64 object-contain filter drop-shadow-2xl"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Latest Blog Posts Section -->
        <section class="py-12 lg:py-16">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-amber-50">
                    Latest Posts
                </h2>
                <a
                    href="/blog"
                    class="text-blue-500 dark:text-blue-400 hover:text-blue-600
                    dark:hover:text-blue-300 font-semibold flex items-center gap-2
                    transition-colors"
                >
                    View all
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {latestPosts.map((post) => (
                    <article class="bg-white dark:bg-gray-800 rounded-xl shadow-lg
                    hover:shadow-xl transition-shadow duration-300 overflow-hidden
                    border border-gray-200 dark:border-gray-700">
                        <div class="p-6 space-y-3">
                            <h3 class="text-xl font-bold text-gray-900 dark:text-amber-50
                            hover:text-blue-500 dark:hover:text-blue-400 transition-colors">
                                <a href={`/blog/${post.data.slug}`} class="block">
                                    {post.data.title}
                                </a>
                            </h3>
                            <p class="text-gray-600 dark:text-amber-200 line-clamp-3">
                                {post.data.description}
                            </p>
                            <div class="pt-2">
                                <a
                                    href={`/blog/${post.data.slug}`}
                                    class="text-blue-500 dark:text-blue-400 hover:text-blue-600
                                    dark:hover:text-blue-300 font-medium inline-flex items-center
                                    gap-1 transition-colors"
                                >
                                    Read more
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <!-- Dad Joke Section -->
        <section class="py-12 lg:py-16">
            <div class="bg-gradient-to-r from-amber-100 to-amber-200 dark:from-gray-800
            dark:to-gray-700 rounded-2xl shadow-lg p-8 lg:p-12 border-2 border-amber-300
            dark:border-gray-600">
                <div class="max-w-3xl mx-auto text-center space-y-4">
                    <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 dark:text-amber-50
                    flex items-center justify-center gap-2">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM7 9a1 1 0 100-2 1 1 0 000 2zm7-1a1 1 0 11-2 0 1 1 0 012 0zm-.464 5.535a1 1 0 10-1.415-1.414 3 3 0 01-4.242 0 1 1 0 00-1.415 1.414 5 5 0 007.072 0z" clip-rule="evenodd" />
                        </svg>
                        Random Dad Joke
                    </h2>
                    <blockquote class="text-xl lg:text-2xl text-gray-800 dark:text-amber-100
                    italic font-medium leading-relaxed">
                        "{dadJoke.joke_text}"
                    </blockquote>
                    <p class="text-sm text-gray-600 dark:text-amber-300">
                        Submitted by: <span class="font-semibold">{dadJoke.author}</span>
                    </p>
                    <p class="text-sm text-gray-600 dark:text-amber-300 pt-2">
                        Want to submit your own? Visit
                        <a
                            href="https://dadjokes.developersandbox.xyz"
                            target="_blank"
                            class="text-blue-600 dark:text-blue-400 hover:text-blue-700
                            dark:hover:text-blue-300 font-semibold underline"
                        >
                            dadjokes.developersandbox.xyz
                        </a>
                    </p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>
