---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = 'Andrew the Coder';
const description = 'Software Engineer and Web Developer';
const permalink = Astro.site.href;

const allPosts = await getCollection('posts');
const featuredPosts = allPosts.filter(post => post.data.featured);
featuredPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

const latestPosts = featuredPosts.slice(0, 3);

const featuredProjects = [
  {
    name: 'Dungeon',
    slug: 'dungeon',
    description: 'Multi-player dungeon crawler powered by WebSockets. A real-time proof-of-concept for browser-based collaborative gaming.',
    tech: 'JavaScript',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'
  },
  {
    name: 'Tetris',
    slug: 'tetris',
    description: 'A fully-featured Tetris clone built with TypeScript. Complete with scoring, levels, and smooth gameplay.',
    tech: 'TypeScript',
    icon: 'M4 4h16v16H4z M8 8h2v2H8zm4 0h2v2h-2zm4 0h2v2h-2z'
  },
  {
    name: 'Conway\'s Game of Life',
    slug: 'conway',
    description: 'Interactive implementation of John Conway\'s cellular automaton. Create patterns and watch life evolve in real-time.',
    tech: 'JavaScript',
    icon: 'M4 4h16v16H4z M8 8h2v2H8zm4 4h2v2h-2zm4 4h2v2h-2z'
  },
  {
    name: 'Enigma Machine',
    slug: 'enigma',
    description: 'Accurate emulator of M3 Enigma machine used in WWII. Encrypt and decrypt messages with historical precision.',
    tech: 'TypeScript',
    icon: 'M12 4V2M12 20v-2M4 12H2m20 0h-2m-2.93-6.07l-1.41 1.41m1.41 9.19l1.41 1.41M7.76 17.24l-1.41-1.41m9.19-9.19l1.41-1.41'
  },
  {
    name: 'Sudoku',
    slug: 'sudoku',
    description: 'Sudoku solver and puzzle generator. Generate new puzzles or let the algorithm solve any grid instantly.',
    tech: 'TypeScript',
    icon: 'M4 4h16v16H4z M4 8h16 M8 4v16 M12 4v16 M16 4v16 M4 12h16'
  }
];

let dadJoke = {
  joke_text: "Why do programmers prefer dark mode? Because light attracts bugs!",
  author: "Anonymous"
};

try {
  const response = await fetch('https://dadjokes.developersandbox.xyz/api/v2/random');
  if (response.ok) {
    dadJoke = await response.json();
  }
} catch (error) {
  console.error('Failed to fetch dad joke:', error);
}
---

<BaseLayout title={title} description={description} permalink={permalink} current="home">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Hero Section -->
        <section class="py-16 lg:py-24">
            <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
                <div class="flex-1 space-y-8 text-center lg:text-left">
                    <div>
                        <p class="text-lg font-medium text-slate-600 dark:text-slate-400 mb-2">
                            Software Engineer & Web Developer
                        </p>
                        <h1 class="text-5xl lg:text-7xl font-bold text-slate-900 dark:text-slate-50 leading-tight">
                            Hi, I'm <span class="gradient-text">Andrew</span>.
                        </h1>
                    </div>
                    <p class="text-xl lg:text-2xl text-slate-600 dark:text-slate-300 leading-relaxed max-w-2xl">
                        Over 20 years of experience crafting digital solutions.
                    </p>
                    <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl">
                        I enjoy the problem-solving aspect of software development and am always
                        looking for new challenges. I also hold advanced degrees in theology and
                        linguistics, and my major hobby is music (I'm a guitar player).
                    </p>
                    <div class="flex flex-wrap gap-4 pt-4 justify-center lg:justify-start">
                        <a
                            href="mailto:info@andrewthecoder.com"
                            class="inline-flex items-center px-8 py-4 bg-slate-900 dark:bg-slate-100 hover:bg-slate-800 dark:hover:bg-slate-200 text-white dark:text-slate-900 font-semibold rounded-xl shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200"
                        >
                            Get in Touch
                        </a>
                        <a
                            href="/about"
                            class="inline-flex items-center px-8 py-4 border-2 border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 hover:border-slate-900 dark:hover:border-slate-100 hover:bg-slate-50 dark:hover:bg-slate-800 font-semibold rounded-xl transition-all duration-200"
                        >
                            Learn More
                        </a>
                    </div>
                </div>
                <div class="flex-1 lg:flex lg:justify-end">
                    <div class="w-full max-w-lg relative">
                        <div class="relative w-full aspect-square">
                            <div class="absolute -top-4 -left-4 w-24 h-24 bg-slate-300 dark:bg-slate-700 rounded-full blur-xl opacity-60 animate-pulse"></div>
                            <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-slate-400 dark:bg-slate-600 rounded-full blur-xl opacity-60 animate-pulse" style="animation-delay: 1s;"></div>
                            <div class="absolute top-1/2 -right-8 w-20 h-20 bg-slate-500 dark:bg-slate-500 rounded-full blur-xl opacity-60 animate-pulse" style="animation-delay: 0.5s;"></div>
                            
                            <div class="relative h-full flex items-center justify-center">
                                <div class="relative">
                                    <div class="absolute inset-0 bg-slate-400 dark:bg-slate-600 rounded-full blur-xl opacity-40 animate-pulse"></div>
                                    <div class="relative w-72 h-72 lg:w-80 lg:h-80 rounded-full bg-slate-200 dark:bg-slate-700 p-1.5 shadow-2xl">
                                        <div class="w-full h-full rounded-full bg-linear-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900 flex items-center justify-center overflow-hidden">
                                            <img
                                                src="/assets/andrew.jpg"
                                                alt="Andrew Coder"
                                                class="w-full h-full object-cover transform hover:scale-110 transition-transform duration-700"
                                            />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Featured Projects Section -->
        <section class="py-12 lg:py-16">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 dark:text-slate-50">
                        Fun Stuff to Look at and Play With!
                    </h2>
                    <p class="text-slate-600 dark:text-slate-400 mt-2">
                        Interactive experiments and demonstrations
                    </p>
                </div>
                <a
                    href="/projects"
                    class="hidden sm:inline-flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 font-semibold transition-colors"
                >
                    View all
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {featuredProjects.map((project) => (
                    <a
                        href={`/${project.slug}`}
                        class="group bg-white dark:bg-slate-900 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-slate-400 dark:hover:border-slate-500"
                    >
                        <div class="p-6 lg:p-8">
                            <div class="flex items-start gap-4">
                                <div class="shrink-0 w-14 h-14 rounded-xl bg-slate-900 dark:bg-slate-100 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                                    <svg class="w-7 h-7 text-white dark:text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={project.icon} />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-xl font-bold text-slate-900 dark:text-slate-50 group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors mb-2">
                                        {project.name}
                                    </h3>
                                    <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-3">
                                        {project.description}
                                    </p>
                                    <div class="flex items-center gap-2">
                                        <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full text-sm font-medium">
                                            {project.tech}
                                        </span>
                                        <span class="text-slate-600 dark:text-slate-400 font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
                                            Launch
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                            </svg>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
            <div class="mt-8 sm:hidden text-center">
                <a
                    href="/projects"
                    class="inline-flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 font-semibold transition-colors"
                >
                    View all projects
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
        </section>

        <!-- Latest Blog Posts Section -->
        <section class="py-12 lg:py-16">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 dark:text-slate-50">
                        Latest Posts
                    </h2>
                    <p class="text-slate-600 dark:text-slate-400 mt-2">
                        Thoughts, tutorials, and insights on software development
                    </p>
                </div>
                <a
                    href="/blog"
                    class="hidden sm:inline-flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 font-semibold transition-colors"
                >
                    View all
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {latestPosts.map((post) => (
                    <article class="group bg-white dark:bg-slate-900 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-slate-400 dark:hover:border-slate-500">
                        <div class="p-6 space-y-4">
                            <h3 class="text-xl font-bold text-slate-900 dark:text-slate-50 group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">
                                <a href={`/blog/${post.data.slug}`} class="block">
                                    {post.data.title}
                                </a>
                            </h3>
                            <p class="text-slate-600 dark:text-slate-400 line-clamp-3 leading-relaxed">
                                {post.data.description}
                            </p>
                            <div class="pt-2 flex items-center justify-between">
                                <a
                                    href={`/blog/${post.data.slug}`}
                                    class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 font-medium inline-flex items-center gap-1 transition-colors group/link"
                                >
                                    Read more
                                    <svg class="w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
            <div class="mt-8 sm:hidden text-center">
                <a
                    href="/blog"
                    class="inline-flex items-center gap-2 text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-semibold transition-colors"
                >
                    View all posts
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
        </section>

        <!-- Dad Joke Section -->
        <section class="py-12 lg:py-16">
            <div class="bg-linear-to-br from-slate-50 via-slate-100 to-slate-200 dark:from-slate-950/50 dark:via-slate-900/50 dark:to-slate-800/50 rounded-3xl shadow-xl p-8 lg:p-12 border border-slate-300/50 dark:border-slate-700/50 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-slate-400/10 dark:bg-slate-600/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
                <div class="max-w-3xl mx-auto text-center space-y-6 relative">
                    <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 dark:text-slate-50 flex items-center justify-center gap-3">
                        <svg class="w-8 h-8 text-slate-600 dark:text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM7 9a1 1 0 100-2 1 1 0 000 2zm7-1a1 1 0 11-2 0 1 1 0 012 0zm-.464 5.535a1 1 0 10-1.415-1.414 3 3 0 01-4.242 0 1 1 0 00-1.415 1.414 5 5 0 007.072 0z" clip-rule="evenodd" />
                        </svg>
                        Random Dad Joke
                    </h2>
                    <blockquote class="text-xl lg:text-2xl text-slate-800 dark:text-slate-200 italic font-medium leading-relaxed">
                        "{dadJoke.joke_text}"
                    </blockquote>
                    <div class="space-y-2">
                        <p class="text-sm text-slate-600 dark:text-slate-400">
                            Submitted by: <span class="font-semibold text-slate-900 dark:text-slate-100">{dadJoke.author}</span>
                        </p>
                        <p class="text-sm text-slate-600 dark:text-slate-400">
                            Want to submit your own? Visit
                            <a
                                href="https://dadjokes.developersandbox.xyz"
                                target="_blank"
                                class="text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-slate-100 font-semibold underline decoration-2 underline-offset-2"
                            >
                                dadjokes.developersandbox.xyz
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>
