---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = 'Andrew the Coder';
const description = 'Software developer building things for fun';
const permalink = Astro.site.href;

const allPosts = await getCollection('posts');
const featuredPosts = allPosts
  .filter(post => post.data.featured)
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())
  .slice(0, 3);

let projects = [];
try {
  const response = await fetch(
    'https://api.github.com/search/repositories?q=user:andrewthecodertx+topic:portfolio-project',
    {
      headers: {
        'Accept': 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28'
      }
    });
  const data = await response.json();
  projects = data.items
    ?.filter((item: any) => item.homepage && item.name !== 'Dad-Jokes-API')
    .map((item: any) => ({
      name: item.name,
      description: item.description || 'No description',
      url: item.html_url,
      language: item.language || 'Unknown',
      homepage: item.homepage
    })) || [];
} catch (error) {
  console.error('Error fetching projects:', error);
}

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

function formatProjectTitle(name: string) {
  return name.replace(/-/g, ' ');
}
---

<BaseLayout title={title} description={description} permalink={permalink} current="home">
  <div class="max-w-3xl mx-auto px-4">

    <!-- Intro -->
    <section class="py-12 border-b border-[#2a2a2a]">
      <div class="space-y-4">
        <p class="text-[#4ade80]">$ whoami</p>
        <div class="space-y-2 text-[#e0e0e0]">
          <p class="text-[#6b7280]">> andrew - software developer</p>
          <p class="text-[#6b7280]">> building things for fun</p>
          <p class="text-[#6b7280]">> 25+ years writing code</p>
        </div>
        <div class="pt-4 flex gap-4 text-sm">
          <a href="mailto:info@andrewthecoder.com" class="text-[#22d3ee] hover:text-[#4ade80] no-underline">email</a>
          <a href="https://github.com/andrewthecodertx" class="text-[#22d3ee] hover:text-[#4ade80] no-underline">github</a>
        </div>
      </div>
    </section>

    <!-- Dad Joke -->
    <section class="py-12 border-b border-[#2a2a2a]">
      <h2 class="text-[#fbbf24] mb-6">## dad joke</h2>
      <p class="text-[#6b7280] text-sm mb-4">
        from <a href="https://dadjokes.developersandbox.xyz" target="_blank" rel="noopener noreferrer" class="text-[#22d3ee] hover:text-[#4ade80] no-underline">Dad Jokes API</a> — a project I built
      </p>
      <div class="space-y-2">
        <p id="joke" class="text-[#e0e0e0]">Loading...</p>
        <p id="joke-author" class="text-[#6b7280] text-sm"></p>
        <button
          id="new-joke"
          class="text-[#22d3ee] hover:text-[#4ade80] text-sm cursor-pointer mt-2"
        >
          another one →
        </button>
      </div>
    </section>

    <!-- Recent Posts -->
    <section class="py-12 border-b border-[#2a2a2a]">
      <h2 class="text-[#fbbf24] mb-6">## recent posts</h2>
      <ul class="space-y-3">
        {featuredPosts.map((post) => (
          <li class="flex flex-col sm:flex-row sm:justify-between gap-1">
            <a href={`/blog/${post.data.slug}`} class="text-[#e0e0e0] hover:text-[#4ade80] no-underline">
              {post.data.title}
            </a>
            <span class="text-[#6b7280] text-sm">{formatDate(post.data.publishDate)}</span>
          </li>
        ))}
      </ul>
      <p class="mt-6">
        <a href="/blog" class="text-[#6b7280] hover:text-[#4ade80] no-underline text-sm">view all posts →</a>
      </p>
    </section>

    <!-- Projects -->
    <section class="py-12 border-b border-[#2a2a2a]">
      <h2 class="text-[#fbbf24] mb-6">## projects</h2>
      <ul class="space-y-4">
        {projects.map((project) => (
          <li>
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-2">
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-[#e0e0e0] hover:text-[#4ade80] no-underline">
                {formatProjectTitle(project.name)}
              </a>
              <span class="text-[#6b7280] text-sm">[{project.language}]</span>
              {project.homepage && (
                <a href={project.homepage} target="_blank" rel="noopener noreferrer" class="text-[#22d3ee] hover:text-[#4ade80] no-underline text-sm">
                  live →
                </a>
              )}
            </div>
            <p class="text-[#6b7280] text-sm mt-1">{project.description}</p>
          </li>
        ))}
      </ul>
      <p class="mt-6">
        <a href="/projects" class="text-[#6b7280] hover:text-[#4ade80] no-underline text-sm">view all projects →</a>
      </p>
    </section>

    <!-- Work with me -->
    <section class="py-12">
      <h2 class="text-[#fbbf24] mb-6">## work with me</h2>
      <p class="text-[#e0e0e0] mb-4">
        I'm available for freelance projects. If you have something interesting
        you'd like to build, let's talk.
      </p>
      <p>
        <a href="mailto:info@andrewthecoder.com" class="text-[#22d3ee] hover:text-[#4ade80] no-underline">
          info@andrewthecoder.com
        </a>
      </p>
    </section>

  </div>

  <script>
    async function fetchJoke() {
      const jokeEl = document.getElementById('joke');
      const authorEl = document.getElementById('joke-author');
      try {
        const res = await fetch('/api/joke');
        const data = await res.json();
        jokeEl.textContent = data.joke_text;
        authorEl.textContent = `— ${data.author}`;
      } catch (e) {
        jokeEl.textContent = 'Why do programmers prefer dark mode? Because light attracts bugs.';
        authorEl.textContent = '— anonymous';
      }
    }

    fetchJoke();
    document.getElementById('new-joke')?.addEventListener('click', fetchJoke);
  </script>
</BaseLayout>
