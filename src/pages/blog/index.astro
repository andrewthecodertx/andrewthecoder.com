---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryPostList from '../../components/CategoryPostList.svelte';

const title = 'Blog';
const description = 'Thoughts on code, philosophy, and life.';
const permalink = `${Astro.site.href}blog`;

let allPosts = await getCollection('posts')
allPosts = allPosts.sort((a, b) =>
  new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

// Group posts by category
const postsByCategory = allPosts.reduce((acc, post) => {
  const categories = post.data.categories || ['Other'];
  categories.forEach((category: string) => {
    if (!acc[category]) acc[category] = [];
    acc[category].push(post);
  });
  return acc;
}, {} as Record<string, typeof allPosts>);

const categoryOrder: Record<string, number> = {
  'Software Development': 1,
  'Science': 2,
  'Theology': 3,
  'Poetry': 4,
};

const categories = Object.keys(postsByCategory).sort((a, b) => {
  const orderA = categoryOrder[a] ?? 999;
  const orderB = categoryOrder[b] ?? 999;
  if (orderA !== orderB) return orderA - orderB;
  return a.localeCompare(b);
});
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <div class="max-w-3xl mx-auto px-4">

    <section class="py-12">
      <h1 class="text-terminal-amber mb-8">## blog</h1>

      <p class="text-terminal-dim mb-8">
        Writing about code, philosophy, and whatever else I find interesting.
      </p>

      {allPosts.length > 0 ? (
        <div class="space-y-10">
          {categories.map((category) => {
            const serializedPosts = postsByCategory[category].map((post) => ({
              title: post.data.title,
              slug: post.data.slug,
              publishDate: post.data.publishDate.toString(),
            }));
            return (
              <CategoryPostList client:load posts={serializedPosts} category={category} />
            );
          })}
        </div>
      ) : (
        <p class="text-terminal-dim">No posts yet. Check back soon.</p>
      )}
    </section>

  </div>
</BaseLayout>
