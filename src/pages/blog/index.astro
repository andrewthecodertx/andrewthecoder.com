---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Blog';
const description = 'Thoughts on code, philosophy, and life.';
const permalink = `${Astro.site.href}blog`;

let allPosts = await getCollection('posts')
allPosts = allPosts.sort((a, b) =>
  new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

// Group posts by category
const postsByCategory = allPosts.reduce((acc, post) => {
  const categories = post.data.categories || ['Other'];
  categories.forEach((category: string) => {
    if (!acc[category]) acc[category] = [];
    acc[category].push(post);
  });
  return acc;
}, {} as Record<string, typeof allPosts>);

const categories = Object.keys(postsByCategory).sort();
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <div class="max-w-3xl mx-auto px-4">

    <section class="py-12">
      <h1 class="text-terminal-amber mb-8">## blog</h1>

      <p class="text-terminal-dim mb-8">
        Writing about code, philosophy, and whatever else I find interesting.
      </p>

      {allPosts.length > 0 ? (
        <div class="space-y-10">
          {categories.map((category) => (
            <div>
              <h2 class="text-terminal-cyan text-sm mb-4 border-b border-terminal-border pb-2">{category}</h2>
              <ul class="space-y-3">
                {postsByCategory[category].map((post) => (
                  <li class="flex flex-col sm:flex-row sm:justify-between gap-1">
                    <a
                      href={`/blog/${post.data.slug}`}
                      class="text-terminal-fg hover:text-terminal-green no-underline"
                    >
                      {post.data.title}
                    </a>
                    <span class="text-terminal-dim text-sm shrink-0">
                      {formatDate(post.data.publishDate)}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-terminal-dim">No posts yet. Check back soon.</p>
      )}
    </section>

  </div>
</BaseLayout>
