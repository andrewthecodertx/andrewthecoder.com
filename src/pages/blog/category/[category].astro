---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CategoryPostList from '../../../components/CategoryPostList.svelte';

export const prerender = true;

export async function getStaticPaths() {
  let allPosts = await getCollection('posts');
  allPosts = allPosts.filter(post => !post.data.hidden);

  // Collect unique categories and build a map of category slug -> { name, posts }
  const categoryMap = new Map<string, { name: string; posts: typeof allPosts }>();

  allPosts.forEach(post => {
    const categories = post.data.categories || ['Other'];
    categories.forEach((category: string) => {
      const slug = category.toLowerCase().replace(/\s+/g, '-');
      if (!categoryMap.has(slug)) {
        categoryMap.set(slug, { name: category, posts: [] });
      }
      categoryMap.get(slug)!.posts.push(post);
    });
  });

  return Array.from(categoryMap.entries()).map(([slug, { name, posts }]) => ({
    params: { category: slug },
    props: {
      categoryName: name,
      posts: posts.sort(
        (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
      ),
    },
  }));
}

const { categoryName, posts } = Astro.props;

const title = `${categoryName} — Blog`;
const description = `Posts in the ${categoryName} category on andrewthecoder.com`;
const permalink = `${Astro.site.href}blog/category/${Astro.params.category}`;

const serializedPosts = posts.map((post: any) => ({
  title: post.data.title,
  slug: post.data.slug,
  publishDate: post.data.publishDate.toString(),
}));
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <div class="max-w-3xl mx-auto px-4">

    <section class="py-12">
      <h2 class="text-terminal-green mb-8">$ blog / <span class="text-terminal-cyan">{categoryName}</span></h2>

      <p class="text-terminal-dim mb-8">
        <a href="/blog" class="text-terminal-dim hover:text-terminal-green no-underline">← all posts</a>
      </p>

      {posts.length > 0 ? (
        <div class="space-y-10">
          <CategoryPostList client:load posts={serializedPosts} category={categoryName} />
        </div>
      ) : (
        <p class="text-terminal-dim">No posts found in this category.</p>
      )}
    </section>

  </div>
</BaseLayout>
