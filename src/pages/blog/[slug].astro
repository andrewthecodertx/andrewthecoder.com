---
import { getCollection, render } from 'astro:content'
import readingTime from 'reading-time'
import BlogLayout from '../../layouts/BlogLayout.astro';

export const prerender = true;
export async function getStaticPaths() {
	const posts = await getCollection('posts')
  return posts.map(p => ({
    params: { slug: p.data.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props
const { title, slug, description, publishDate, author, image, github, demo } = post.data;
const readingTimeEstimate = readingTime(post.body).text
const permalink = `${Astro.site.href}blog/${slug}`;
const { Content } = await render(post)

const authors = await getCollection('authors');
const currentAuthor = authors.find(a => a.data.name === author);
---

<BlogLayout title={title} description={description} permalink={permalink} image={image} current="blog">
  <header>
    <p>{publishDate} ~ {readingTimeEstimate}</p>
    <div class="post-meta">
      {post.data.categories.length > 0 && (
        <p>Categories: {post.data.categories.map(category => 
          <a href={`/blog/category/${category}`}>{category}</a>).reduce((prev, curr) => [prev, ', ', curr])}
        </p>
      )}
      {post.data.tags.length > 0 && (
        <p>Tags: {post.data.tags.map(tag => 
          <a href={`/blog/tag/${tag}`}>{tag}</a>).reduce((prev, curr) => [prev, ', ', curr])}
        </p>
      )}
      <div class="flex">
        {github && (
          <p><a href={post.data.github} target="_blank" rel="noopener noreferrer">View on GitHub</a></p>
        )}
        {demo && (
          <p><a href={post.data.demo} target="_blank" rel="noopener noreferrer">Live Demo</a></p>
        )}
      </div>
    </div>
    <h1>{title}</h1>
    <hr />
    {image && (<div class="container"><img src={image} alt={`Image for ${title}`} /></div>)}
  </header>
  <div class="container">
    <article class="content">
      <Content />
    </article>
    <hr />
    {currentAuthor && (
      <div class="author-info">
        <h3>About {currentAuthor.data.name}</h3>
        {currentAuthor.data.bio && <p>{currentAuthor.data.bio}</p>}
      </div>
    )}

    {post.data.comments_enabled && (
      <div class="comments-section">
        <script src="https://giscus.app/client.js"
                data-repo="andrewthecodertx/blogcomments"
                data-repo-id="R_kgDOPULhRg"
                data-category="General"
                data-category-id="DIC_kwDOPULhRs4CtgJ4"
                data-mapping="title"
                data-strict="1"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="bottom"
                data-theme="dark"
                data-lang="en"
                crossorigin="anonymous"
                async>
        </script>
      </div>
    )}
  </div>
</BlogLayout>

<style>
  header {
    text-align: center;
    margin-bottom: 2em;
  }

  header h1 {
    font-size: 2.8em; /* Consistent with new global h1 */
    margin-bottom: 0.5em;
  }

  header p {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    font-weight: 400; /* Lighter weight */
    font-size: 0.9em;
    text-transform: none; /* Remove uppercase */
  }

  header hr {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2em auto;
    width: 50%;
  }

  .flex {
    display: flex;
    gap: 1em;
    justify-content: center;
    flex-wrap: wrap;
  }

  .post-meta {
    margin-top: 1em;
    font-size: 0.85em;
    color: var(--text-secondary);
  }

  .post-meta a {
    color: var(--primary-color);
    text-decoration: none;
  }

  .post-meta a:hover {
    text-decoration: underline;
  }

  .author-info {
    margin-top: 3em;
    padding: 1.5em;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background-color: var(--card-background);
  }

  .author-info h3 {
    margin-top: 0;
    font-size: 1.5em;
  }

  .comments-section {
    margin-top: 3em;
    padding-top: 2em;
    border-top: 1px solid var(--border-color);
  }
</style>
